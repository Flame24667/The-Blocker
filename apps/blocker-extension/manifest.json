{
  "manifest_version": 3,
  "name": "The Blocker Browser Helper",
  "version": "0.1.0",
  "description": "Detects possible ad and tracker domains while browsing.",
  "permissions": [
    "storage",
    "tabs",
    "webRequest",
    "webNavigation",
    "declarativeNetRequest",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://127.0.0.1:4780/*",
    "http://localhost:4780/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "the_blocker_ad_rules",
        "enabled": true,
        "path": "rules/ad_rules.json"
      },
      {
        "id": "the_blocker_tracker_rules",
        "enabled": true,
        "path": "rules/tracker_rules.json"
      }
    ]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["src/turtlecute-cosmetic.css"],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "action": {
    "default_title": "The Blocker",
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  }
}