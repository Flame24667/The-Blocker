# =========================
# The Blocker - Git Ignore
# =========================

# Rust build output
/target/
**/target/

# Rust backup files
**/*.rs.bk

# Cargo local config
.cargo/config.toml

# Tauri build output
/apps/blocker-ui/src-tauri/target/
/apps/blocker-ui/src-tauri/gen/

# Node / Vite / frontend
/apps/blocker-ui/node_modules/
/apps/blocker-ui/dist/
/apps/blocker-ui/.vite/

# Browser extension release/package output
/apps/blocker-extension-release/
/apps/blocker-extension/dist/
/apps/blocker-extension/build/
/apps/blocker-extension/out/
/apps/blocker-extension/.output/
/apps/blocker-extension/.web-ext-artifacts/
/apps/blocker-extension/web-ext-artifacts/

/apps/blocker-extension/*.zip
/apps/blocker-extension/*.crx
/apps/blocker-extension/*.pem

# Browser extension local logs
/apps/blocker-extension/*.log
/apps/blocker-extension/npm-debug.log*
/apps/blocker-extension/yarn-debug.log*
/apps/blocker-extension/yarn-error.log*
/apps/blocker-extension/pnpm-debug.log*

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Local database/runtime files
*.db
*.db-shm
*.db-wal
blocker.db
blocker-dev.db
blocker-test.db

# Local environment files
.env
.env.*
!.env.example

# Windows / editor junk
Thumbs.db
Desktop.ini
.DS_Store

# IDE/editor
.vscode/
.idea/
*.swp
*.swo

# Tauri generated bundles/installers
/apps/blocker-ui/src-tauri/target/release/bundle/

# Temporary files
tmp/
temp/
*.tmp